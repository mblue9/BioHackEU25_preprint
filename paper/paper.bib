	pages = {164},
	file = {Full Text PDF:/Users/rioualen/Zotero/storage/KYI7F8JL/Ison et al. - 2019 - The bio.tools registry of software tools and data .pdf:application/pdf;Snapshot:/Users/rioualen/Zotero/storage/Y44888PF/s13059-019-1772-6.html:text/html},
